READER_TYPE MULTI_READER
MULTI_READER_TYPE{0} OGCGEOPACKAGE
MULTI_READER_KEYWORD{0} OGCGEOPACKAGE_1
MULTI_READER_GEN_DIRECTIVES{0} DYNAMIC_WORKFLOW,yes,ENCODE_FEATURE_TYPE_AND_ATTR_NAMES,YES,OPEN_SINGLE_RASTER_AS_SUBDATASET,YES,USE_SEARCH_ENVELOPE,NO,ADVANCED_GROUP,,OGCGEOPACKAGE_EXPOSE_FORMAT_ATTRS,,QUERY_FEATURE_TYPES_FOR_MERGE_FILTERS,Yes,SEARCH_ENVELOPE_MAXY,0,SEARCH_ENVELOPE_MINX,0,SEARCH_ENVELOPE_COORDINATE_SYSTEM,,READ_NULLS,YES,READ_BOOLEANS_AS_YES_NO,YES,ENFORCE_FOREIGN_KEY_INTEGRITY,YES,CLIP_TO_ENVELOPE,NO,TABLELIST,,READER_REPLACE_INVALID_CHARS,NO,SEARCH_ENVELOPE_MAXX,0,_MERGE_SCHEMAS,YES,SEARCH_ENVELOPE_MINY,0,EXPOSE_PRIMARY_KEY_ATTRIBUTE,YES,EXPOSE_ATTRS_GROUP,
