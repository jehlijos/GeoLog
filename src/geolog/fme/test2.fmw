#! <COMMENTS>
#! <COMMENT
#!   IDENTIFIER="14"
#!   COMMENT_VALUE="&lt;!DOCTYPE HTML PUBLIC &quot;-//W3C//DTD HTML 4.0//EN&quot; &quot;http://www.w3.org/TR/REC-html40/strict.dtd&quot;&gt;&#10;&lt;html&gt;&lt;head&gt;&lt;meta name=&quot;qrichtext&quot; content=&quot;1&quot; /&gt;&lt;meta charset=&quot;utf-8&quot; /&gt;&lt;style type=&quot;text/css&quot;&gt;&#10;p, li { white-space: pre-wrap; }&#10;hr { height: 1px; border-width: 0; }&#10;li.unchecked::marker { content: &quot;\2610&quot;; }&#10;li.checked::marker { content: &quot;\2612&quot;; }&#10;&lt;/style&gt;&lt;/head&gt;&lt;body style=&quot; font-family:&apos;MS Shell Dlg 2&apos;; font-size:9pt; font-weight:400; font-style:normal;&quot;&gt;&#10;&lt;table border=&quot;0&quot; style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px;&quot; cellspacing=&quot;2&quot; cellpadding=&quot;0&quot;&gt;&#10;&lt;tr&gt;&#10;&lt;td style=&quot; vertical-align:top; border-top-color:#e6e6e6; border-right-color:#e6e6e6; border-bottom-color:#e6e6e6; border-left-color:#e6e6e6;&quot;&gt;&#10;&lt;p style=&quot; margin-top:12px; margin-bottom:12px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px; line-height:20px;&quot;&gt;&lt;span style=&quot; font-family:&apos;Segoe UI&apos;; font-size:14px; font-weight:700;&quot;&gt;Bufferer (Round caps) → ArcStroker → AreaBuilder&lt;/span&gt;&lt;/p&gt;&#10;&lt;p style=&quot; margin-top:12px; margin-bottom:12px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-family:&apos;Segoe UI&apos;; font-size:14px;&quot;&gt;Tato kombinace je použitá, protože standardní buffer s &lt;/span&gt;&lt;span style=&quot; font-family:&apos;Segoe UI&apos;; font-size:14px; font-style:italic;&quot;&gt;End Cap = None&lt;/span&gt;&lt;span style=&quot; font-family:&apos;Segoe UI&apos;; font-size:14px;&quot;&gt; vytvářel mezery a artefakty v rozích.&lt;br /&gt;Round caps sice generují &lt;/span&gt;&lt;span style=&quot; font-family:&apos;Segoe UI&apos;; font-size:14px; font-style:italic;&quot;&gt;CurvePolygon&lt;/span&gt;&lt;span style=&quot; font-family:&apos;Segoe UI&apos;; font-size:14px;&quot;&gt;, ale po průchodu přes ArcStroker a AreaBuilder vznikne čistý &lt;/span&gt;&lt;span style=&quot; font-family:&apos;Segoe UI&apos;; font-size:14px; font-style:italic;&quot;&gt;Polygon/Multipolygon&lt;/span&gt;&lt;span style=&quot; font-family:&apos;Segoe UI&apos;; font-size:14px;&quot;&gt; bez křivkových segmentů a bez nedotahů.&lt;/span&gt;&lt;/p&gt;&#10;&lt;p style=&quot; margin-top:12px; margin-bottom:12px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-family:&apos;Segoe UI&apos;; font-size:14px;&quot;&gt;Výsledek: kvalitní, spojitý buffer bez artefaktů, plně lineární geometrie.&lt;/span&gt;&lt;/p&gt;&lt;/td&gt;&lt;/tr&gt;&#10;&lt;tr&gt;&#10;&lt;td&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/body&gt;&lt;/html&gt;"
