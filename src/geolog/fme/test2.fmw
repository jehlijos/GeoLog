PRIMARY_DEST_KEYWORD{0} OGCGEOPACKAGE_2
PRIMARY_DEST_GEN_DIRECTIVES{0} DATASET_TEMPLATE,,DESTINATION_DATASETTYPE_VALIDATION,Yes,VERSION,1.2,ENFORCE_GEOMETRY_COLUMN_CONSTRAINTS,YES,COORDINATE_SYSTEM_GRANULARITY,FEATURE_TYPE,ADD_WRITER_NEXT_ACTION,automatic,TRANSACTION_SIZE,5000,OVERWRITE_DATASET,NO,GEOPACKAGE_WRT_ADV_PARM,,EXPOSE_PRIMARY_KEY_ATTRIBUTE,YES,ENCODE_FEATURE_TYPE_AND_ATTR_NAMES,YES,WRITE_NULLS,YES
