OGCGEOPACKAGE_2_DEF vrstva_test_2   geopackage_type              geopackage_multipolygon   fme_feature_operation        INSERT   fme_table_handling           DROP_CREATE   fme_selection_method         MATCH_ID   fme_match_id_attribute       ""   geopackage_geometry_column   geom   geopackage_primary_index_column ""   geopackage_create_spatial_index Yes   geopackage_z_capability      OPTIONAL   geopackage_m_capability      OPTIONAL   Typprac                      text(7)   Dotace                       text(11)   Kraj                         text(32)   Etapa                        text(6)   id                           int,PrimaryKey   TU                           text
